{
  "name": "react-render-budget",
  "version": "0.1.0",
  "description": "Measure React render counts and render budgets in Playwright tests.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moritzbrantner/react-render-budget.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.ts",
      "import": "./dist/playwright.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "typecheck": "npm run typecheck:lib && npm run pages:typecheck",
    "typecheck:lib": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "npm run build && npm --prefix examples/playwright-react ci && npm --prefix examples/playwright-react test",
    "test:watch": "vitest",
    "bench": "mkdir -p benchmark-results && vitest bench --run --outputJson benchmark-results/vitest-bench.json",
    "bench:watch": "vitest bench",
    "pages:data": "node scripts/generate-pages-data.mjs",
    "pages:dev": "npm run pages:data && vite --config pages/vite.config.ts --host 127.0.0.1 --port 5173",
    "pages:build": "npm run pages:data && vite build --config pages/vite.config.ts",
    "pages:preview": "vite preview --config pages/vite.config.ts --host 127.0.0.1 --port 4173",
    "pages:typecheck": "npm run pages:data && tsc --noEmit -p pages/tsconfig.json",
    "pack:dry-run": "npm pack --dry-run",
    "pack:check": "npm run build && npm run pack:dry-run"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0",
    "react": ">=18.0.0 || >=19.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@types/node": "^20.19.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "jsdom": "^26.1.0",
    "lucide-react": "^1.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
